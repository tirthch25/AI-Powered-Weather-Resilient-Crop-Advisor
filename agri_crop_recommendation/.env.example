# =============================================================================
#  AI Crop Advisor — Environment Configuration Template
# =============================================================================
#  HOW TO USE:
#    1. Copy this file:  copy .env.example .env        (Windows)
#                        cp  .env.example .env          (Linux/Mac)
#    2. Fill in your values below (follow the setup guides for each section)
#    3. NEVER commit the .env file to git (it is already in .gitignore)
# =============================================================================


# ── LLM Provider ──────────────────────────────────────────────────────────────
#
#  Choose which AI model powers the AI Crop Advisor chat assistant.
#
#  "ollama"  → Local LLaMA / Gemma model via Ollama  (free, private, offline)
#              Automatically falls back to Gemini if Ollama is not running.
#
#  "gemini"  → Google Gemini API  (cloud, requires API key below)
#              Falls back to Ollama if Gemini key is missing/invalid.
#
LLM_PROVIDER=ollama


# ── Ollama Setup (used when LLM_PROVIDER=ollama) ──────────────────────────────
#
#  SETUP GUIDE — follow these steps once:
#
#  [Windows]
#    1. Download installer → https://ollama.com/download/windows
#    2. Run the installer (adds `ollama` to PATH automatically)
#    3. Open a new terminal and pull a model:
#         ollama pull llama3.2
#    4. Ollama starts automatically as a background service.
#       To check it is running:  ollama list
#
#  [Linux]
#    1. Run:  curl -fsSL https://ollama.com/install.sh | sh
#    2. Pull a model:  ollama pull llama3.2
#    3. Start server:  ollama serve          (or it auto-starts after install)
#
#  [Mac]
#    1. Download app → https://ollama.com/download/mac
#    2. Open the app (it runs as a menu-bar service)
#    3. Pull a model:  ollama pull llama3.2
#
#  Recommended models (pick one — set OLLAMA_MODEL to your choice):
#    llama3.2      — 3B params, fast, good quality       ← default
#    llama3.1      — 8B params, better reasoning
#    gemma3:2b     — 2B params, lightest, fastest
#    mistral       — 7B params, good multilingual
#
#  To pull a different model:  ollama pull <model-name>
#  To list downloaded models:  ollama list
#
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434


# ── Gemini API Key Setup (used when LLM_PROVIDER=gemini OR as Ollama fallback) ─
#
#  SETUP GUIDE — follow these steps to get a free API key:
#
#    Step 1. Open → https://aistudio.google.com/app/apikey
#            (Sign in with your Google account)
#
#    Step 2. Click "Create API Key"
#            → Choose "Create API key in new project"  (or pick an existing one)
#
#    Step 3. Copy the key (starts with "AIzaSy...") and paste it below
#            as GEMINI_API_KEY=AIzaSy...
#
#    Step 4. (Optional) Repeat Steps 1–3 for 2 extra keys to avoid rate limits.
#            Paste them as GEMINI_API_KEY_2 and GEMINI_API_KEY_3.
#            The system rotates through all keys automatically.
#
#  Free tier limits (as of 2025):
#    • gemini-2.5-flash-lite → 1,500 requests/day, 15 requests/minute (per key)
#    • Having 3 keys triples your effective free quota.
#
#  Leave unused key slots blank — do NOT delete the variable names.
#
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=


# ── Quick Setup Examples ───────────────────────────────────────────────────────
#
#  [Option A] Use LLaMA locally (no internet, fully private):
#    LLM_PROVIDER=ollama
#    OLLAMA_MODEL=llama3.2
#    GEMINI_API_KEY=           ← leave blank, or add one as safety fallback
#
#  [Option B] Use Gemini only (no GPU needed, cloud-based):
#    LLM_PROVIDER=gemini
#    GEMINI_API_KEY=AIzaSy...  ← required
#
#  [Option C] Use LLaMA + Gemini as automatic backup (recommended):
#    LLM_PROVIDER=ollama
#    OLLAMA_MODEL=llama3.2
#    GEMINI_API_KEY=AIzaSy...  ← kicks in automatically if Ollama goes down
#
#  [Option D] PARAM Shavak / HPC deployment (use this on C-DAC supercomputer):
#    LLM_PROVIDER=gemini       ← Ollama cannot run on HPC batch nodes
#    GEMINI_API_KEY=AIzaSy...  ← required; get free key at aistudio.google.com
#    # OLLAMA_MODEL=llama3.2   ← comment out on HPC
#    # OLLAMA_BASE_URL=...     ← comment out on HPC
#
# =============================================================================
